# Core
PORT=3001
UVICORN_HOST=0.0.0.0
NODE_ENV=development
TRUST_PROXY=true

# CORS
ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_MAX_AGE=3600

# JWT (REQUIRED)
JWT_SECRET=change_me_to_a_long_random_string
JWT_ISSUER=football-live-scores-backend
JWT_AUDIENCE=football-live-scores-mobile
JWT_ACCESS_TOKEN_TTL_S=86400

# MySQL (set either MYSQL_URL or individual vars)
# MYSQL_URL can be: mysql://host:port/db OR mysql+pymysql://user:pass@host:port/db
MYSQL_URL=mysql://localhost:5000/myapp
MYSQL_USER=appuser
MYSQL_PASSWORD=dbuser123
MYSQL_DB=myapp
MYSQL_PORT=5000
# Optional if you use discrete vars:
MYSQL_HOST=localhost

# Integrations (REQUIRED for data)
API_FOOTBALL_KEY=your_api_football_key
API_FOOTBALL_HOST=v3.football.api-sports.io
NEWSAPI_KEY=your_newsapi_key

# Caching / rate limit protection
CACHE_TTL_S=30
RATE_LIMIT_WINDOW_S=60
RATE_LIMIT_MAX=100

# Realtime poll interval (seconds)
LIVE_POLL_INTERVAL_S=15
